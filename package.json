{
  "name": "selfme",
  "version": "2026.7.3",
  "type": "module",
  "description": "Local-first agent CLI for real terminal work.",
  "author": "q1d40",
  "license": "MIT",
  "homepage": "https://selfme.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SelfMeAI/SelfMe.git"
  },
  "bugs": {
    "url": "https://github.com/SelfMeAI/SelfMe/issues"
  },
  "keywords": [
    "agent",
    "ai",
    "cli",
    "terminal",
    "coding-agent",
    "local-first"
  ],
  "bin": {
    "selfme": "dist/index.js"
  },
  "files": [
    "dist/app",
    "dist/editor",
    "dist/index.js",
    "dist/providers",
    "dist/runtime",
    "dist/storage",
    "dist/terminal",
    "dist/tools",
    "dist/types",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.0.6",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm build",
    "start": "node dist/index.js",
    "smoke:agent": "tsc -p tsconfig.json && node dist/smoke/agent-regression.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "zod": "^4.1.12"
  }
}

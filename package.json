{
  "name": "@selfme/cli",
  "version": "2026.6.18",
  "private": true,
  "type": "module",
  "bin": {
    "selfme": "./dist/index.js"
  },
  "packageManager": "pnpm@11.0.6",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "smoke:agent": "./node_modules/.bin/tsc -p tsconfig.json && node ./dist/smoke/agent-regression.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "zod": "^4.1.12"
  }
}
